PERX_DATA_MODE=database

DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@YOUR_POOLER_HOST:5432/postgres"

DIRECT_URL="postgresql://postgres:YOUR_DATABASE_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

