# PerX Environment Configuration
# Copy to .env and replace placeholders with real values.
# Never commit .env or .env.local.

# --- Data Mode ---
# Options: "database" (requires PostgreSQL) or "mock" (development only, no database).
# WARNING: "mock" mode is strictly prohibited when NODE_ENV=production.
PERX_DATA_MODE=database

# --- Registration ---
# Options: "closed", "open_beta", or "public".
# Missing mode defaults safely to "closed" in deployed environments.
# Open beta requires a positive PERX_BETA_MAX_USERS value.
PERX_SIGNUP_MODE=open_beta
PERX_BETA_MAX_USERS=10

# --- Database ---
# Runtime should use the pooled Supabase URL. URL-encode passwords.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_URL_ENCODED_DATABASE_PASSWORD@YOUR_POOLER_HOST:5432/postgres"
# Prisma migration/status operations should use the direct Supabase URL. URL-encode passwords.
DIRECT_URL="postgresql://postgres:YOUR_URL_ENCODED_DATABASE_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# --- Session ---
SESSION_COOKIE_NAME="perx_session"
AUTH_SESSION_DAYS="30"

# --- Application ---
# Local: http://localhost:3000
# Vercel Preview/Staging: https://your-staging-domain.example
# Production: https://your-production-domain.example
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UPLOAD_MAX_BYTES="5242880"
LOG_LEVEL="info"
# Optional until an error-monitoring provider is configured.
# Leave empty to disable external error monitoring.
ERROR_MONITORING_DSN=""

# --- Preview Routes ---
# Preview routes are disabled by default.
# Set to "true" to enable static preview routes at /preview/*.
# Preview never uses a database and never grants real access.
PERX_ENABLE_PREVIEW=false

# --- Seed Safety ---
# Baseline seed creates immutable roles and categories only.
# Development users and sample data are disabled by default and require a clearly non-production target.
# For remote development/staging databases, set PERX_SEED_DATABASE_LABEL to a human-verified
# non-production target name before enabling either optional seed flag.
PERX_DEPLOY_ENV="development"
PERX_SEED_DATABASE_LABEL=""
PERX_ALLOW_DEV_SEED=false
PERX_ALLOW_SAMPLE_DATA=false
PERX_SEED_DRY_RUN=false

# --- Development Seed User ---
# Used by prisma/seed.ts only when PERX_ALLOW_DEV_SEED=true.
# This user signs in through the normal sign-in page.
# Do not commit real passwords.
DEV_TEST_USER_EMAIL=""
DEV_TEST_USER_USERNAME=""
DEV_TEST_USER_PASSWORD=""

# --- Optional Admin Seed User ---
# Only created when PERX_ALLOW_DEV_SEED=true and ALL three values are provided.
# Do not commit real passwords.
# Development/staging only - do not use in production.
DEV_ADMIN_EMAIL=""
DEV_ADMIN_USERNAME=""
DEV_ADMIN_PASSWORD=""
